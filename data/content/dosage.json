  "error_traps": [
    {
      "id": "trap-units",
      "title": "Unit Conversion Errors",
      "trap": "Confusing mg, mcg, g, and units",
      "fix": "Convert to one system before calculating; mcg ≠ mg (1000× difference).",
      "example": "Ordered 0.5 mg but label in mcg — 500 mcg",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-decimal",
      "title": "Decimal Point Errors",
      "trap": "Misplaced decimal — tenfold overdose",
      "fix": "Leading zero for doses <1 (0.5 mg not .5 mg); no trailing zero on whole numbers.",
      "example": "2.0 mg misread as 20 mg",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-division",
      "title": "Inverted Division",
      "trap": "Dividing available by ordered instead of ordered by available",
      "fix": "Desired ÷ Have — ask 'how many units to get desired dose?'",
      "example": "Ordered 500 mg, tablet 250 mg → 2 tablets not 0.5",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-time",
      "title": "Time Unit Errors",
      "trap": "Using minutes when formula needs hours for mL/hr",
      "fix": "Always convert minutes to hours for pump rates.",
      "example": "1000 mL over 8 hr = 125 mL/hr not 1000÷8 min",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-drop",
      "title": "Wrong Drop Factor",
      "trap": "Assuming 15 gtt/mL when tubing is 10 or 60",
      "fix": "Read drop factor on IV tubing package every time.",
      "example": "Microdrip always 60 gtt/mL",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-weight",
      "title": "Weight in Pounds",
      "trap": "Using lbs instead of kg in weight-based calc",
      "fix": "kg = lbs ÷ 2.2 before multiplying dose/kg.",
      "example": "44 lbs = 20 kg not 44 kg",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-rounding",
      "title": "Premature Rounding",
      "trap": "Rounding intermediate steps causes error",
      "fix": "Round only at final step per policy.",
      "example": "0.333 × 3 = 0.999 → clinical judgment on 1 mL",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    },
    {
      "id": "trap-concentration",
      "title": "Reconstitution Concentration",
      "trap": "Using vial total volume instead of final concentration",
      "fix": "Read label after reconstitution — mg per mL.",
      "example": "1 g in 10 mL = 100 mg/mL",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      }
    }
  ],
