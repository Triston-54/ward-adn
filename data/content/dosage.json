  "practice_problems": [
    {
      "id": "dos-p01",
      "calc_type": "tablet_capsule",
      "question": "Order: Digoxin 0.25 mg PO daily. Available: 0.125 mg tablets. How many tablets?",
      "options": [
        "0.5 tablet",
        "1 tablet",
        "2 tablets",
        "2.5 tablets"
      ],
      "correct_index": 2,
      "answer": "2 tablets",
      "explanation": "0.25 ÷ 0.125 = 2 tablets.",
      "trap": "Dividing 0.125 ÷ 0.25 gives wrong answer.",
      "nursing_note": "Assess apical pulse 1 full minute before giving.",
      "source": {
        "title": "Open RN — Nursing Pharmacology",
        "citation": "Open RN OER Dosage Calculations",
        "verified_date": "2026-06"
      },
      "clinical_why": "Digoxin has narrow therapeutic index — double-check calculation and hold if apical pulse <60."
    },
    {
